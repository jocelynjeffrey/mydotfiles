[user]
	name = Jocelyn Jeffrey
	email = jocelynjeffrey@gmail.com

[core]
	editor = claude
	abbrev = 12
	attributesfile = ~/.gitattributes
	excludesfile = ~/.gitignore_global
	autocrlf = input
	ignorecase = false

[color]
	ui = always

[color "branch"]
	current = green bold
	local = green
	remote = yellow

[color "diff"]
	frag = magenta
	meta = yellow
	new = green
	old = red

[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = "red bold 52"
	newNormal = "green bold"
	newHighlight = "green bold 22"

[grep]
	extendRegexp = true

[credential]
	helper = osxkeychain

[fetch]
	prune = true

[pull]
	rebase = true

[init]
	defaultBranch = main

[merge]
	conflictstyle = diff3
